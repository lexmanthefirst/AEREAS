# Application
APP_NAME=Academic Writing Evaluation API
DEBUG=true

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=documents

# Database (required — must be asyncpg)
DATABASE_URL=postgresql+asyncpg://acrev_user:acrev_password@localhost:5435/acrev_db
REDIS_URL=redis://localhost:6379

# LLM Configuration
# Set GEMINI_API_KEY to enable LLM-powered workers (omit for rule-based mode)
# GEMINI_API_KEY=your-gemini-api-key-here
USE_LLM_SYNTHESIS=false
WORKER_MODEL_NAME=gemini-2.5-flash
SYNTHESIS_MODEL_NAME=gemini-2.5-flash
REVIEW_MODEL_NAME=gemini-2.5-flash
REVISION_MODEL_NAME=gemini-2.5-flash
LLM_REQUEST_TIMEOUT=45.0

# Research providers
ENABLE_WEB_RESEARCH=true
WEB_RESEARCH_MAX_QUERIES=3
DUCKDUCKGO_API_URL=https://api.duckduckgo.com/
CROSSREF_API_URL=https://api.crossref.org/works
RESEARCH_USER_AGENT=academic-review-system/0.1.0
