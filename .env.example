# Application
APP_NAME=Academic Writing Evaluation API
DEBUG=true

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=documents

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/evaldb
REDIS_URL=redis://localhost:6379

# LLM Configuration (optional)
GEMINI_API_KEY=x-api-key
USE_MODELS=True
USE_LLM_SYNTHESIS=True
SYNTHESIS_MODEL_NAME=gemini-2.5-flash
REVIEW_MODEL_NAME=gemini-2.5-flash
REVISION_MODEL_NAME=gemini-2.5-flash

# NLP model identifiers
GRAMMAR_MODEL_NAME=vennify/t5-base-grammar-correction
ARGUMENTATION_MODEL_NAME=microsoft/deberta-v3-base
TONE_MODEL_NAME=bert-base-uncased
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Research providers
ENABLE_WEB_RESEARCH=True
WEB_RESEARCH_MAX_QUERIES=3
DUCKDUCKGO_API_URL=https://api.duckduckgo.com/
CROSSREF_API_URL="https://api.crossref.org/works
RESEARCH_USER_AGENT=academic-review-system/0.1.0
