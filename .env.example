# Application
APP_NAME=Academic Writing Evaluation API
DEBUG=true

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=documents

# Database (required — must be asyncpg)
DATABASE_URL=postgresql+asyncpg://acrev_user:acrev_password@localhost:5435/acrev_db
REDIS_URL=redis://localhost:6379

# LLM Configuration
# Choose provider: gemini, openrouter, or auto
LLM_PROVIDER=openrouter

# Gemini
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter
# OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_X_TITLE=Academic Writing Evaluation API

USE_LLM_SYNTHESIS=true
WORKER_MODEL_NAME=openai/gpt-4.1-mini
SYNTHESIS_MODEL_NAME=openai/gpt-4.1-mini
REVIEW_MODEL_NAME=openai/gpt-4.1-mini
REVISION_MODEL_NAME=openai/gpt-4.1-mini
# For OpenRouter, use a provider-qualified model name, e.g. openai/gpt-4.1-mini
LLM_REQUEST_TIMEOUT=45.0

# Research providers
ENABLE_WEB_RESEARCH=true
WEB_RESEARCH_MAX_QUERIES=3
DUCKDUCKGO_API_URL=https://api.duckduckgo.com/
CROSSREF_API_URL=https://api.crossref.org/works
RESEARCH_USER_AGENT=academic-review-system/0.1.0
