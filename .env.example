# Application
APP_NAME=Academic Writing Evaluation API
DEBUG=true

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=documents

# Database (required — must be asyncpg)
DATABASE_URL=postgresql+asyncpg://acrev_user:acrev_password@localhost:5435/acrev_db
REDIS_URL=redis://localhost:6379

# LLM Configuration (OpenRouter)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers (shown on https://openrouter.ai/rankings)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AEREAS

USE_LLM_SYNTHESIS=true
# Sonnet for high-quality specialist workers + the final revision rewrite.
WORKER_MODEL_NAME=anthropic/claude-sonnet-4.5
REVISION_MODEL_NAME=anthropic/claude-sonnet-4.5
# Faster/cheaper models for the two big-prompt jobs to stay under the timeout.
REVIEW_MODEL_NAME=anthropic/claude-haiku-4.5
SYNTHESIS_MODEL_NAME=openai/gpt-4o-mini
LLM_REQUEST_TIMEOUT=120.0

# Research providers
ENABLE_WEB_RESEARCH=true
WEB_RESEARCH_MAX_QUERIES=3
DUCKDUCKGO_API_URL=https://api.duckduckgo.com/
CROSSREF_API_URL=https://api.crossref.org/works
RESEARCH_USER_AGENT=academic-review-system/0.1.0
